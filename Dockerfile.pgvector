# Use PostgreSQL 16 with pgvector extension
FROM postgres:16

# Install dependencies for pgvector
RUN apt-get update && \
    apt-get install -y \
    build-essential \
    postgresql-server-dev-16 \
    git \
    clang \
    llvm-dev \
    cmake && \
    rm -rf /var/lib/apt/lists/*

# Clone and install pgvector
RUN git clone --branch v0.8.0 https://github.com/pgvector/pgvector.git /tmp/pgvector && \
    cd /tmp/pgvector && \
    make clean && \
    make OPTFLAGS="-O2" && \
    make install

# Remove the empty directory and create the init_db.sql file
RUN rm -rf /scripts/init_db.sql && \
    mkdir -p /scripts

# Create initialization script
RUN echo '-- Initialize pgvector extension' > /scripts/init_db.sql && \
    echo 'CREATE EXTENSION IF NOT EXISTS vector;' >> /scripts/init_db.sql && \
    echo '-- Create test vector table' >> /scripts/init_db.sql && \
    echo 'CREATE TABLE IF NOT EXISTS test_vectors (' >> /scripts/init_db.sql && \
    echo '    id SERIAL PRIMARY KEY,' >> /scripts/init_db.sql && \
    echo '    embedding VECTOR(1536) NOT NULL,' >> /scripts/init_db.sql && \
    echo '    metadata JSONB,' >> /scripts/init_db.sql && \
    echo '    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP' >> /scripts/init_db.sql && \
    echo ');' >> /scripts/init_db.sql && \
    echo '-- Verify pgvector installation' >> /scripts/init_db.sql && \
    echo "SELECT 'pgvector installed successfully' as status;" >> /scripts/init_db.sql

# Copy initialization scripts
COPY scripts/init_db.sql /docker-entrypoint-initdb.d/
COPY scripts/migrations/ /docker-entrypoint-initdb.d/migrations/

# Create a script to run all migrations
RUN echo '#!/bin/bash' > /docker-entrypoint-initdb.d/00-run-migrations.sh && \
    echo 'for migration in /docker-entrypoint-initdb.d/migrations/*.sql; do' >> /docker-entrypoint-initdb.d/00-run-migrations.sh && \
    echo '  echo "Running migration: $(basename "$migration")"' >> /docker-entrypoint-initdb.d/00-run-migrations.sh && \
    echo '  psql -U "$POSTGRES_USER" -d "$POSTGRES_DB" -f "$migration"' >> /docker-entrypoint-initdb.d/00-run-migrations.sh && \
    echo 'done' >> /docker-entrypoint-initdb.d/00-run-migrations.sh && \
    chmod +x /docker-entrypoint-initdb.d/00-run-migrations.sh

# Set proper permissions
RUN chown -R postgres:postgres /docker-entrypoint-initdb.d/

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD pg_isready -U ${POSTGRES_USER} -d ${POSTGRES_DB}

# Expose PostgreSQL port
EXPOSE 5432

# Start PostgreSQL
CMD ["postgres"]