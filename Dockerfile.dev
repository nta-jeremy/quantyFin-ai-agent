# Development Dockerfile for QuantyFinAI Agent
# Includes development tools and allows hot-reloading

FROM python:3.12-slim

# Set working directory
WORKDIR /app

# Set environment variables
ENV PYTHONDONTWRITEBYTECODE 1
ENV PYTHONUNBUFFERED 1
ENV PYTHONPATH /app

# Install system dependencies
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        build-essential \
        libpq-dev \
        gcc \
        curl \
        git \
        vim \
        && rm -rf /var/lib/apt/lists/*

# Install poetry
RUN pip install poetry

# Configure poetry for development
RUN poetry config virtualenvs.in-project true

# Copy poetry files first for better layer caching
COPY pyproject.toml poetry.lock* ./

# Install development dependencies
RUN poetry install --with=dev --no-root --no-interaction --no-ansi

# Copy application code (mounted as volume in compose)
COPY . .

# Create non-root user
RUN useradd --create-home --shell /bin/bash app \
    && chown -R app:app /app
USER app

# Expose port
EXPOSE 8000

# Development health check (simplified)
HEALTHCHECK --interval=60s --timeout=30s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:8000/api/v1/health || exit 1

# Default command (overridden in compose for development)
CMD ["poetry", "run", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]